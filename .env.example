HL_WALLET_ADDRESS=0xYOUR_SIGNER_WALLET
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional. If omitted, defaults to HL_WALLET_ADDRESS.
HL_ACCOUNT_ADDRESS=

COPY_TARGET_ADDRESS=0xTARGET_WALLET_TO_COPY
COPY_COINS=xyz:SILVER

# Scaling modes: proportional, fixed_ratio, fixed_size, fixed_notional
COPY_SCALING_MODE=fixed_notional
COPY_FIXED_RATIO=1.0
COPY_FIXED_SIZE=1.0
COPY_FIXED_NOTIONAL_USD=20.0

# Position / trade caps
COPY_MAX_TRADE_USD=40.0
COPY_MAX_POSITION_USD=200.0
COPY_MIN_TRADE_USD=11.0
COPY_MAX_DAILY_TRADES=200

# HIP-3 leverage is isolated per coin
COPY_LEVERAGE=5

# Reconcile modes: state, delta, lifecycle
COPY_RECONCILE_MODE=lifecycle
COPY_SYNC_STARTUP=false
COPY_POLL_INTERVAL=3.0
COPY_SLIPPAGE_BPS=10.0

COPY_DRY_RUN=true
COPY_LOG_LEVEL=INFO
