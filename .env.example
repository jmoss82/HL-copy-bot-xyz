# -- Your HyperLiquid Wallet ------------------------------------
HL_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
HL_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS

# -- Target Trader ----------------------------------------------
COPY_TARGET_ADDRESS=0xTARGET_WALLET_ADDRESS

# -- Scaling ----------------------------------------------------
COPY_SCALING_MODE=fixed_notional
COPY_FIXED_NOTIONAL_USD=20
COPY_MAX_TRADE_USD=40

# -- Risk -------------------------------------------------------
COPY_LEVERAGE=5
COPY_IS_CROSS=false
COPY_MAX_POSITION_USD=200

# -- Execution --------------------------------------------------
COPY_POLL_INTERVAL=3.0
COPY_RECONCILE_MODE=state
COPY_SLIPPAGE_BPS=10.0
COPY_MIN_TRADE_USD=11.0

# -- Coins ------------------------------------------------------
# Mix of standard HL perps and XYZ HIP-3 pairs (xyz: prefix)
# Example: COPY_COINS=APT,MON,xyz:GOLD,xyz:SILVER
COPY_COINS=xyz:GOLD,xyz:SILVER

# -- Startup ----------------------------------------------------
COPY_SYNC_STARTUP=false

# -- Safety -----------------------------------------------------
COPY_MAX_DAILY_TRADES=200
COPY_DRY_RUN=false

# -- Logging ----------------------------------------------------
COPY_LOG_LEVEL=INFO
